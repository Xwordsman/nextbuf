# Application
APP_URL=http://localhost:3000
HOSTNAME=0.0.0.0
PORT=3000
TZ=Asia/Shanghai
LOG_LEVEL=info
LOG_FORMAT=pretty

# Build metadata
NEXTBUF_VERSION=0.9.0
NEXTBUF_COMMIT=development
NEXTBUF_BUILD_TIME=

# PostgreSQL 18
DATABASE_URL=postgresql://nextbuf:nextbuf@127.0.0.1:5432/nextbuf
DATABASE_DIRECT_URL=
DATABASE_POOL_SIZE=10
DATABASE_STATEMENT_TIMEOUT_MS=15000

# Redis 8 and BullMQ
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_PREFIX=nextbuf
WORKER_CONCURRENCY=5
WORKER_SHUTDOWN_TIMEOUT_MS=30000
WORKER_HEARTBEAT_INTERVAL_MS=10000
WORKER_STALE_AFTER_MS=30000
WORKER_SCHEDULER_POLL_INTERVAL_MS=5000
WORKER_TASK_LOCK_TIMEOUT_MS=300000
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=50
OUTBOX_LOCK_TIMEOUT_MS=60000
JOB_REMOVE_COMPLETE_AFTER=1000
JOB_REMOVE_FAILED_AFTER=5000

# Identity and sessions
AUTH_SECRET=replace-with-at-least-32-random-characters
AUTH_REGISTRATION_MODE=open
AUTH_SESSION_EXPIRES_IN_SECONDS=2592000
AUTH_SESSION_UPDATE_AGE_SECONDS=86400
AUTH_VERIFICATION_EXPIRES_IN_SECONDS=86400
AUTH_PASSWORD_RESET_EXPIRES_IN_SECONDS=3600
AUTH_TRUSTED_ORIGINS=
AUTH_TRUSTED_PROXIES=

# Encrypted asynchronous email delivery
MAIL_PAYLOAD_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=NextBuf <noreply@localhost>

# Object storage, avatars and community attachments
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=data/uploads
AVATAR_MAX_UPLOAD_BYTES=1048576
ATTACHMENT_MAX_UPLOAD_BYTES=20971520
ATTACHMENT_MAX_IMAGE_PIXELS=40000000
ATTACHMENT_ORPHAN_GRACE_HOURS=24

# Required when STORAGE_DRIVER=s3; S3_ENDPOINT is optional for AWS S3
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false

# Optional first OAuth provider
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
