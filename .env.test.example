NODE_ENV=test
RUN_INTEGRATION_TESTS=true
LOG_LEVEL=error
LOG_FORMAT=json
NEXTBUF_VERSION=0.12.0
DATABASE_URL=postgresql://nextbuf:nextbuf_test@127.0.0.1:55432/nextbuf_test
REDIS_URL=redis://127.0.0.1:56379/0
REDIS_PREFIX=nextbuf_test
WORKER_CONCURRENCY=1
WORKER_SCHEDULER_POLL_INTERVAL_MS=1000
WORKER_TASK_LOCK_TIMEOUT_MS=30000
OUTBOX_POLL_INTERVAL_MS=100
OUTBOX_BATCH_SIZE=10
AUTH_SECRET=nextbuf-test-auth-secret-at-least-32-characters
SETUP_TOKEN=nextbuf-test-setup-token-at-least-32-characters
AUTH_REGISTRATION_MODE=open
MAIL_PAYLOAD_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
SMTP_HOST=127.0.0.1
SMTP_PORT=11025
SMTP_SECURE=false
SMTP_FROM=NextBuf Test <noreply@nextbuf.test>
MAILPIT_API_URL=http://127.0.0.1:18025
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=data/test-uploads
ATTACHMENT_MAX_UPLOAD_BYTES=20971520
ATTACHMENT_MAX_IMAGE_PIXELS=40000000
ATTACHMENT_ORPHAN_GRACE_HOURS=24
