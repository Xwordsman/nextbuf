generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String          @id @default(uuid()) @db.Uuid
  uid                 Int             @unique(map: "users_uid_key") @default(autoincrement())
  username            String          @unique(map: "users_username_key") @db.VarChar(24)
  name                String          @db.VarChar(80)
  email               String          @unique(map: "users_email_key") @db.VarChar(320)
  emailVerified       Boolean         @default(false) @map("email_verified")
  image               String?         @db.Text
  status              String          @default("pending") @db.VarChar(32)
  activatedAt         DateTime?       @map("activated_at") @db.Timestamptz(6)
  usernameChangedAt   DateTime?       @map("username_changed_at") @db.Timestamptz(6)
  deletionRequestedAt DateTime?       @map("deletion_requested_at") @db.Timestamptz(6)
  deletionScheduledAt DateTime?       @map("deletion_scheduled_at") @db.Timestamptz(6)
  createdAt           DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  sessions            Session[]
  accounts            Account[]
  profile             Profile?
  usernameAliases     UsernameAlias[]

  @@index([status], map: "users_status_idx")
  @@map("users")
}

model Profile {
  userId       String   @id @map("user_id") @db.Uuid
  bio          String   @default("") @db.VarChar(500)
  website      String?  @db.VarChar(2048)
  isPublic     Boolean  @default(true) @map("is_public")
  showActivity Boolean  @default(true) @map("show_activity")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model UsernameAlias {
  id        String   @id @default(uuid()) @db.Uuid
  username  String   @unique(map: "username_aliases_username_key") @db.VarChar(24)
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt], map: "username_aliases_user_created_idx")
  @@map("username_aliases")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  token     String   @unique(map: "auth_sessions_token_key") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  ipAddress String?  @map("ip_address") @db.VarChar(64)
  userAgent String?  @map("user_agent") @db.Text
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt], map: "auth_sessions_user_expires_idx")
  @@map("auth_sessions")
}

model Account {
  id                    String    @id @default(uuid()) @db.Uuid
  accountId             String    @map("account_id") @db.VarChar(255)
  providerId            String    @map("provider_id") @db.VarChar(80)
  userId                String    @map("user_id") @db.Uuid
  accessToken           String?   @map("access_token") @db.Text
  refreshToken          String?   @map("refresh_token") @db.Text
  idToken               String?   @map("id_token") @db.Text
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at") @db.Timestamptz(6)
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at") @db.Timestamptz(6)
  scope                 String?   @db.Text
  password              String?   @db.Text
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId], map: "auth_accounts_provider_account_key")
  @@index([userId], map: "auth_accounts_user_idx")
  @@map("auth_accounts")
}

model Verification {
  id         String   @id @default(uuid()) @db.Uuid
  identifier String   @db.Char(64)
  value      String   @db.Text
  expiresAt  DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([identifier], map: "auth_verifications_identifier_idx")
  @@index([expiresAt], map: "auth_verifications_expires_idx")
  @@map("auth_verifications")
}

model RegistrationInvite {
  id         String    @id @default(uuid()) @db.Uuid
  codeHash   String    @unique(map: "registration_invites_code_hash_key") @map("code_hash") @db.Char(64)
  label      String?   @db.VarChar(120)
  maxUses    Int       @default(1) @map("max_uses")
  useCount   Int       @default(0) @map("use_count")
  expiresAt  DateTime? @map("expires_at") @db.Timestamptz(6)
  disabledAt DateTime? @map("disabled_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([expiresAt], map: "registration_invites_expires_idx")
  @@map("registration_invites")
}

model IdentityAuditEvent {
  id        String   @id @default(uuid()) @db.Uuid
  eventType String   @map("event_type") @db.VarChar(160)
  userId    String?  @map("user_id") @db.Uuid
  sessionId String?  @map("session_id") @db.Uuid
  ipHash    String?  @map("ip_hash") @db.Char(64)
  metadata  Json?    @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId, createdAt], map: "identity_audit_user_created_idx")
  @@index([eventType, createdAt], map: "identity_audit_event_created_idx")
  @@map("identity_audit_events")
}

model EmailDelivery {
  id                   String    @id @default(uuid()) @db.Uuid
  kind                 String    @db.VarChar(80)
  recipient            String    @db.VarChar(320)
  subject              String    @db.VarChar(255)
  ciphertext           String    @db.Text
  initializationVector String    @map("initialization_vector") @db.VarChar(32)
  authTag              String    @map("auth_tag") @db.VarChar(32)
  status               String    @default("pending") @db.VarChar(32)
  attempts             Int       @default(0)
  lastError            String?   @map("last_error") @db.Text
  sentAt               DateTime? @map("sent_at") @db.Timestamptz(6)
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([status, createdAt], map: "email_deliveries_status_created_idx")
  @@map("email_deliveries")
}

model SystemState {
  key       String   @id @db.VarChar(120)
  value     Json     @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("system_state")
}

model OutboxEvent {
  id             String    @id @default(uuid()) @db.Uuid
  topic          String    @db.VarChar(160)
  version        Int       @default(1)
  payload        Json      @db.JsonB
  idempotencyKey String    @unique(map: "outbox_events_idempotency_key_key") @map("idempotency_key") @db.VarChar(255)
  occurredAt     DateTime  @default(now()) @map("occurred_at") @db.Timestamptz(6)
  availableAt    DateTime  @default(now()) @map("available_at") @db.Timestamptz(6)
  publishedAt    DateTime? @map("published_at") @db.Timestamptz(6)
  lockedAt       DateTime? @map("locked_at") @db.Timestamptz(6)
  lockOwner      String?   @map("lock_owner") @db.VarChar(160)
  attempts       Int       @default(0)
  lastError      String?   @map("last_error") @db.Text
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([publishedAt, availableAt], map: "outbox_events_publishable_idx")
  @@index([lockedAt], map: "outbox_events_locked_at_idx")
  @@map("outbox_events")
}

model ProcessedJob {
  id             String   @id @default(uuid()) @db.Uuid
  queueName      String   @map("queue_name") @db.VarChar(120)
  jobName        String   @map("job_name") @db.VarChar(160)
  idempotencyKey String   @map("idempotency_key") @db.VarChar(255)
  result         Json?    @db.JsonB
  completedAt    DateTime @default(now()) @map("completed_at") @db.Timestamptz(6)

  @@unique([queueName, idempotencyKey], map: "processed_jobs_queue_idempotency_key")
  @@index([completedAt], map: "processed_jobs_completed_at_idx")
  @@map("processed_jobs")
}

model WorkerHeartbeat {
  workerId    String    @id @map("worker_id") @db.VarChar(160)
  status      String    @db.VarChar(32)
  version     String    @db.VarChar(64)
  startedAt   DateTime  @map("started_at") @db.Timestamptz(6)
  heartbeatAt DateTime  @map("heartbeat_at") @db.Timestamptz(6)
  stoppedAt   DateTime? @map("stopped_at") @db.Timestamptz(6)
  metadata    Json?     @db.JsonB

  @@index([heartbeatAt], map: "worker_heartbeats_heartbeat_at_idx")
  @@map("worker_heartbeats")
}
