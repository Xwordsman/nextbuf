generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       String                      @id @default(uuid()) @db.Uuid
  uid                      Int                         @unique(map: "users_uid_key") @default(autoincrement())
  username                 String                      @unique(map: "users_username_key") @db.VarChar(24)
  name                     String                      @db.VarChar(80)
  email                    String                      @unique(map: "users_email_key") @db.VarChar(320)
  emailVerified            Boolean                     @default(false) @map("email_verified")
  image                    String?                     @db.Text
  status                   String                      @default("pending") @db.VarChar(32)
  activatedAt              DateTime?                   @map("activated_at") @db.Timestamptz(6)
  usernameChangedAt        DateTime?                   @map("username_changed_at") @db.Timestamptz(6)
  deletionRequestedAt      DateTime?                   @map("deletion_requested_at") @db.Timestamptz(6)
  deletionScheduledAt      DateTime?                   @map("deletion_scheduled_at") @db.Timestamptz(6)
  createdAt                DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(6)
  sessions                 Session[]
  accounts                 Account[]
  profile                  Profile?
  usernameAliases          UsernameAlias[]
  communityTopics          CommunityTopic[]            @relation("CommunityTopicAuthor")
  communityPosts           CommunityPost[]             @relation("CommunityPostAuthor")
  deletedCommunityPosts    CommunityPost[]             @relation("CommunityPostDeleter")
  communityRevisions       CommunityPostRevision[]     @relation("CommunityRevisionEditor")
  communityMentions        CommunityPostMention[]      @relation("CommunityMentionUser")
  communityAttachments     CommunityAttachment[]       @relation("CommunityAttachmentUploader")
  communityPostDrafts      CommunityPostDraft[]
  communityRoles           CommunityRoleAssignment[]   @relation("CommunityRoleUser")
  grantedCommunityRoles    CommunityRoleAssignment[]   @relation("CommunityRoleGrantor")
  communityAuditEvents     CommunityAuditEvent[]       @relation("CommunityAuditActor")
  interactionPostLikes     InteractionPostLike[]
  interactionBookmarks     InteractionTopicBookmark[]
  interactionFollowing     InteractionUserFollow[]     @relation("InteractionFollower")
  interactionFollowers     InteractionUserFollow[]     @relation("InteractionFollowed")
  interactionTopicFollows  InteractionTopicFollow[]
  interactionReadStates    InteractionTopicReadState[]
  notificationsReceived    Notification[]              @relation("NotificationRecipient")
  notificationsActed       Notification[]              @relation("NotificationActor")
  notificationPreferences  NotificationPreference[]
  workerReplayRequests     WorkerJobFailure[]          @relation("WorkerFailureReplayRequester")
  moderationReports        ModerationReport[]          @relation("ModerationReporter")
  reportsAgainstUser       ModerationReport[]          @relation("ModerationReportedUser")
  moderationCasesCreated   ModerationCase[]            @relation("ModerationCaseCreator")
  moderationCasesAssigned  ModerationCase[]            @relation("ModerationCaseAssignee")
  moderationCasesAgainst   ModerationCase[]            @relation("ModerationCaseReportedUser")
  moderationActions        ModerationAction[]          @relation("ModerationActionActor")
  moderationActionsAgainst ModerationAction[]          @relation("ModerationActionTargetUser")
  sanctions                ModerationSanction[]        @relation("ModerationSanctionUser")
  sanctionsCreated         ModerationSanction[]        @relation("ModerationSanctionCreator")
  sanctionsRevoked         ModerationSanction[]        @relation("ModerationSanctionRevoker")
  governanceAuditEvents    GovernanceAuditEvent[]      @relation("GovernanceAuditActor")
  trustState               TrustUserState?
  trustRulesCreated        TrustRuleVersion[]          @relation("TrustRuleCreator")
  trustHistories           TrustLevelHistory[]         @relation("TrustHistoryUser")
  trustHistoryActions      TrustLevelHistory[]         @relation("TrustHistoryActor")
  trustBatchesRequested    TrustRecalculationBatch[]   @relation("TrustBatchRequester")
  siteSettingsUpdated      SiteSetting[]               @relation("SiteSettingUpdater")

  @@index([status], map: "users_status_idx")
  @@map("users")
}

model CommunityNode {
  id                  String                    @id @default(uuid()) @db.Uuid
  slug                String                    @unique(map: "community_nodes_slug_key") @db.VarChar(64)
  name                String                    @db.VarChar(80)
  description         String                    @default("") @db.VarChar(500)
  color               String                    @db.Char(7)
  icon                String                    @db.VarChar(32)
  sortOrder           Int                       @default(0) @map("sort_order")
  visibility          String                    @default("public") @db.VarChar(32)
  archivedAt          DateTime?                 @map("archived_at") @db.Timestamptz(6)
  createdAt           DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)
  topics              CommunityTopic[]
  roleAssignments     CommunityRoleAssignment[]
  auditEvents         CommunityAuditEvent[]
  moderationActions   ModerationAction[]
  moderationSanctions ModerationSanction[]

  @@index([visibility, archivedAt, sortOrder], map: "community_nodes_browse_idx")
  @@map("community_nodes")
}

model CommunityTopic {
  id                    String                      @id @default(uuid()) @db.Uuid
  number                Int                         @unique(map: "community_topics_number_key") @default(autoincrement())
  nodeId                String                      @map("node_id") @db.Uuid
  authorId              String                      @map("author_id") @db.Uuid
  title                 String                      @db.VarChar(120)
  status                String                      @default("draft") @db.VarChar(32)
  deletedFromStatus     String?                     @map("deleted_from_status") @db.VarChar(32)
  isPinned              Boolean                     @default(false) @map("is_pinned")
  isEssence             Boolean                     @default(false) @map("is_essence")
  replyCount            Int                         @default(0) @map("reply_count")
  viewCount             Int                         @default(0) @map("view_count")
  bookmarkCount         Int                         @default(0) @map("bookmark_count")
  nextPostPosition      Int                         @default(2) @map("next_post_position")
  lastActivityAt        DateTime                    @default(now()) @map("last_activity_at") @db.Timestamptz(6)
  publishedAt           DateTime?                   @map("published_at") @db.Timestamptz(6)
  editedAt              DateTime?                   @map("edited_at") @db.Timestamptz(6)
  closedAt              DateTime?                   @map("closed_at") @db.Timestamptz(6)
  deletedAt             DateTime?                   @map("deleted_at") @db.Timestamptz(6)
  createdAt             DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(6)
  node                  CommunityNode               @relation(fields: [nodeId], references: [id], onDelete: Restrict)
  author                User                        @relation("CommunityTopicAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  posts                 CommunityPost[]
  postDrafts            CommunityPostDraft[]
  auditEvents           CommunityAuditEvent[]
  interactionBookmarks  InteractionTopicBookmark[]
  interactionFollows    InteractionTopicFollow[]
  interactionReadStates InteractionTopicReadState[]
  interactionViews      InteractionTopicView[]
  notifications         Notification[]
  moderationReports     ModerationReport[]
  moderationCases       ModerationCase[]
  moderationActions     ModerationAction[]

  @@index([status, isPinned, lastActivityAt, number], map: "community_topics_feed_idx")
  @@index([nodeId, status, isPinned, lastActivityAt, number], map: "community_topics_node_feed_idx")
  @@index([authorId, status, updatedAt], map: "community_topics_author_status_idx")
  @@map("community_topics")
}

model CommunityPost {
  id                String                    @id @default(uuid()) @db.Uuid
  topicId           String                    @map("topic_id") @db.Uuid
  authorId          String                    @map("author_id") @db.Uuid
  position          Int
  status            String                    @default("draft") @db.VarChar(32)
  bodySource        String                    @map("body_source") @db.Text
  revisionCount     Int                       @default(1) @map("revision_count")
  likeCount         Int                       @default(0) @map("like_count")
  quotedPostId      String?                   @map("quoted_post_id") @db.Uuid
  deletedById       String?                   @map("deleted_by_id") @db.Uuid
  deletedReason     String?                   @map("deleted_reason") @db.VarChar(500)
  editedAt          DateTime?                 @map("edited_at") @db.Timestamptz(6)
  deletedAt         DateTime?                 @map("deleted_at") @db.Timestamptz(6)
  createdAt         DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)
  topic             CommunityTopic            @relation(fields: [topicId], references: [id], onDelete: Cascade)
  author            User                      @relation("CommunityPostAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  quotedPost        CommunityPost?            @relation("CommunityPostQuote", fields: [quotedPostId], references: [id], onDelete: SetNull)
  quotes            CommunityPost[]           @relation("CommunityPostQuote")
  deletedBy         User?                     @relation("CommunityPostDeleter", fields: [deletedById], references: [id], onDelete: SetNull)
  revisions         CommunityPostRevision[]
  mentions          CommunityPostMention[]
  attachments       CommunityPostAttachment[]
  quotedDrafts      CommunityPostDraft[]      @relation("CommunityPostDraftQuote")
  auditEvents       CommunityAuditEvent[]
  interactionLikes  InteractionPostLike[]
  notifications     Notification[]
  moderationReports ModerationReport[]
  moderationCases   ModerationCase[]
  moderationActions ModerationAction[]

  @@unique([topicId, position], map: "community_posts_topic_position_key")
  @@index([authorId, createdAt], map: "community_posts_author_created_idx")
  @@index([topicId, status], map: "community_posts_topic_status_idx")
  @@index([deletedById], map: "community_posts_deleted_by_idx")
  @@map("community_posts")
}

model CommunityPostRevision {
  id          String                        @id @default(uuid()) @db.Uuid
  postId      String                        @map("post_id") @db.Uuid
  editorId    String                        @map("editor_id") @db.Uuid
  version     Int
  title       String?                       @db.VarChar(120)
  bodySource  String                        @map("body_source") @db.Text
  source      String                        @db.VarChar(32)
  reason      String?                       @db.VarChar(500)
  createdAt   DateTime                      @default(now()) @map("created_at") @db.Timestamptz(6)
  post        CommunityPost                 @relation(fields: [postId], references: [id], onDelete: Cascade)
  editor      User                          @relation("CommunityRevisionEditor", fields: [editorId], references: [id], onDelete: Restrict)
  attachments CommunityRevisionAttachment[]

  @@unique([postId, version], map: "community_post_revisions_post_version_key")
  @@index([editorId, createdAt], map: "community_post_revisions_editor_created_idx")
  @@map("community_post_revisions")
}

model CommunityPostDraft {
  id           String                         @id @default(uuid()) @db.Uuid
  topicId      String                         @map("topic_id") @db.Uuid
  authorId     String                         @map("author_id") @db.Uuid
  quotedPostId String?                        @map("quoted_post_id") @db.Uuid
  bodySource   String                         @default("") @map("body_source") @db.Text
  createdAt    DateTime                       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime                       @updatedAt @map("updated_at") @db.Timestamptz(6)
  topic        CommunityTopic                 @relation(fields: [topicId], references: [id], onDelete: Cascade)
  author       User                           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  quotedPost   CommunityPost?                 @relation("CommunityPostDraftQuote", fields: [quotedPostId], references: [id], onDelete: SetNull)
  attachments  CommunityPostDraftAttachment[]

  @@unique([topicId, authorId], map: "community_post_drafts_topic_author_key")
  @@index([authorId, updatedAt], map: "community_post_drafts_author_updated_idx")
  @@index([quotedPostId], map: "community_post_drafts_quoted_post_idx")
  @@map("community_post_drafts")
}

model CommunityPostMention {
  postId          String        @map("post_id") @db.Uuid
  mentionedUserId String        @map("mentioned_user_id") @db.Uuid
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  post            CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  mentionedUser   User          @relation("CommunityMentionUser", fields: [mentionedUserId], references: [id], onDelete: Cascade)

  @@id([postId, mentionedUserId], map: "community_post_mentions_pkey")
  @@index([mentionedUserId, createdAt], map: "community_post_mentions_user_created_idx")
  @@map("community_post_mentions")
}

model CommunityAttachment {
  id              String                         @id @default(uuid()) @db.Uuid
  uploaderId      String                         @map("uploader_id") @db.Uuid
  storageDriver   String                         @map("storage_driver") @db.VarChar(16)
  storageKey      String                         @map("storage_key") @db.VarChar(500)
  processedKey    String?                        @map("processed_key") @db.VarChar(500)
  originalName    String                         @map("original_name") @db.VarChar(255)
  contentType     String                         @map("content_type") @db.VarChar(100)
  processedType   String?                        @map("processed_type") @db.VarChar(100)
  kind            String                         @db.VarChar(16)
  status          String                         @default("pending") @db.VarChar(16)
  sizeBytes       Int                            @map("size_bytes")
  checksumSha256  String                         @map("checksum_sha256") @db.Char(64)
  width           Int?
  height          Int?
  processingError String?                        @map("processing_error") @db.Text
  orphanedAt      DateTime?                      @map("orphaned_at") @db.Timestamptz(6)
  createdAt       DateTime                       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime                       @updatedAt @map("updated_at") @db.Timestamptz(6)
  uploader        User                           @relation("CommunityAttachmentUploader", fields: [uploaderId], references: [id], onDelete: Restrict)
  posts           CommunityPostAttachment[]
  revisions       CommunityRevisionAttachment[]
  drafts          CommunityPostDraftAttachment[]

  @@unique([storageDriver, storageKey], map: "community_attachments_storage_key")
  @@index([uploaderId, createdAt], map: "community_attachments_uploader_created_idx")
  @@index([status, orphanedAt], map: "community_attachments_status_orphaned_idx")
  @@map("community_attachments")
}

model CommunityPostAttachment {
  postId       String              @map("post_id") @db.Uuid
  attachmentId String              @map("attachment_id") @db.Uuid
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  post         CommunityPost       @relation(fields: [postId], references: [id], onDelete: Cascade)
  attachment   CommunityAttachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)

  @@id([postId, attachmentId], map: "community_post_attachments_pkey")
  @@index([attachmentId], map: "community_post_attachments_attachment_idx")
  @@map("community_post_attachments")
}

model CommunityRevisionAttachment {
  revisionId   String                @map("revision_id") @db.Uuid
  attachmentId String                @map("attachment_id") @db.Uuid
  createdAt    DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  revision     CommunityPostRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  attachment   CommunityAttachment   @relation(fields: [attachmentId], references: [id], onDelete: Cascade)

  @@id([revisionId, attachmentId], map: "community_revision_attachments_pkey")
  @@index([attachmentId], map: "community_revision_attachments_attachment_idx")
  @@map("community_revision_attachments")
}

model CommunityPostDraftAttachment {
  draftId      String              @map("draft_id") @db.Uuid
  attachmentId String              @map("attachment_id") @db.Uuid
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  draft        CommunityPostDraft  @relation(fields: [draftId], references: [id], onDelete: Cascade)
  attachment   CommunityAttachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)

  @@id([draftId, attachmentId], map: "community_post_draft_attachments_pkey")
  @@index([attachmentId], map: "community_post_draft_attachments_attachment_idx")
  @@map("community_post_draft_attachments")
}

model CommunityRoleAssignment {
  id          String         @id @default(uuid()) @db.Uuid
  userId      String         @map("user_id") @db.Uuid
  role        String         @db.VarChar(32)
  nodeId      String?        @map("node_id") @db.Uuid
  scopeKey    String         @map("scope_key") @db.VarChar(64)
  grantedById String?        @map("granted_by_id") @db.Uuid
  reason      String?        @db.VarChar(500)
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  user        User           @relation("CommunityRoleUser", fields: [userId], references: [id], onDelete: Cascade)
  node        CommunityNode? @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  grantedBy   User?          @relation("CommunityRoleGrantor", fields: [grantedById], references: [id], onDelete: SetNull)

  @@unique([userId, role, scopeKey], map: "community_role_assignments_user_role_scope_key")
  @@index([role, scopeKey], map: "community_role_assignments_role_scope_idx")
  @@index([nodeId], map: "community_role_assignments_node_idx")
  @@index([grantedById], map: "community_role_assignments_granted_by_idx")
  @@map("community_role_assignments")
}

model ModerationCase {
  id              String               @id @default(uuid()) @db.Uuid
  number          Int                  @unique(map: "moderation_cases_number_key") @default(autoincrement())
  targetType      String               @map("target_type") @db.VarChar(24)
  targetKey       String               @map("target_key") @db.VarChar(96)
  activeTargetKey String?              @unique(map: "moderation_cases_active_target_key") @map("active_target_key") @db.VarChar(96)
  topicId         String?              @map("topic_id") @db.Uuid
  postId          String?              @map("post_id") @db.Uuid
  reportedUserId  String?              @map("reported_user_id") @db.Uuid
  status          String               @default("open") @db.VarChar(24)
  priorityScore   Int                  @default(0) @map("priority_score")
  summary         String?              @db.VarChar(500)
  createdById     String?              @map("created_by_id") @db.Uuid
  assignedToId    String?              @map("assigned_to_id") @db.Uuid
  resolvedAt      DateTime?            @map("resolved_at") @db.Timestamptz(6)
  dismissedAt     DateTime?            @map("dismissed_at") @db.Timestamptz(6)
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  topic           CommunityTopic?      @relation(fields: [topicId], references: [id], onDelete: Restrict)
  post            CommunityPost?       @relation(fields: [postId], references: [id], onDelete: Restrict)
  reportedUser    User?                @relation("ModerationCaseReportedUser", fields: [reportedUserId], references: [id], onDelete: Restrict)
  createdBy       User?                @relation("ModerationCaseCreator", fields: [createdById], references: [id], onDelete: SetNull)
  assignedTo      User?                @relation("ModerationCaseAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  reports         ModerationReport[]
  actions         ModerationAction[]
  sanctions       ModerationSanction[]

  @@index([status, priorityScore, createdAt], map: "moderation_cases_queue_idx")
  @@index([topicId, createdAt], map: "moderation_cases_topic_idx")
  @@index([postId, createdAt], map: "moderation_cases_post_idx")
  @@index([reportedUserId, createdAt], map: "moderation_cases_user_idx")
  @@index([createdById], map: "moderation_cases_created_by_idx")
  @@index([assignedToId], map: "moderation_cases_assigned_to_idx")
  @@map("moderation_cases")
}

model ModerationReport {
  id                 String          @id @default(uuid()) @db.Uuid
  reporterId         String          @map("reporter_id") @db.Uuid
  caseId             String          @map("case_id") @db.Uuid
  targetType         String          @map("target_type") @db.VarChar(24)
  targetKey          String          @map("target_key") @db.VarChar(96)
  activeTargetKey    String?         @map("active_target_key") @db.VarChar(96)
  topicId            String?         @map("topic_id") @db.Uuid
  postId             String?         @map("post_id") @db.Uuid
  reportedUserId     String?         @map("reported_user_id") @db.Uuid
  reason             String          @db.VarChar(32)
  details            String          @default("") @db.VarChar(2000)
  status             String          @default("open") @db.VarChar(24)
  reporterTrustLevel Int             @map("reporter_trust_level")
  weight             Int             @default(1)
  snapshot           Json            @db.JsonB
  resolvedAt         DateTime?       @map("resolved_at") @db.Timestamptz(6)
  createdAt          DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  reporter           User            @relation("ModerationReporter", fields: [reporterId], references: [id], onDelete: Restrict)
  case               ModerationCase  @relation(fields: [caseId], references: [id], onDelete: Restrict)
  topic              CommunityTopic? @relation(fields: [topicId], references: [id], onDelete: Restrict)
  post               CommunityPost?  @relation(fields: [postId], references: [id], onDelete: Restrict)
  reportedUser       User?           @relation("ModerationReportedUser", fields: [reportedUserId], references: [id], onDelete: Restrict)

  @@unique([reporterId, activeTargetKey], map: "moderation_reports_reporter_active_target_key")
  @@index([caseId, createdAt], map: "moderation_reports_case_created_idx")
  @@index([reporterId, createdAt], map: "moderation_reports_reporter_created_idx")
  @@index([topicId], map: "moderation_reports_topic_idx")
  @@index([postId], map: "moderation_reports_post_idx")
  @@index([reportedUserId], map: "moderation_reports_reported_user_idx")
  @@map("moderation_reports")
}

model ModerationAction {
  id           String              @id @default(uuid()) @db.Uuid
  caseId       String              @map("case_id") @db.Uuid
  actorId      String              @map("actor_id") @db.Uuid
  actorRoles   Json                @map("actor_roles") @db.JsonB
  action       String              @db.VarChar(40)
  targetType   String              @map("target_type") @db.VarChar(24)
  targetKey    String              @map("target_key") @db.VarChar(96)
  topicId      String?             @map("topic_id") @db.Uuid
  postId       String?             @map("post_id") @db.Uuid
  targetUserId String?             @map("target_user_id") @db.Uuid
  nodeId       String?             @map("node_id") @db.Uuid
  reason       String              @db.VarChar(500)
  beforeState  Json                @map("before_state") @db.JsonB
  afterState   Json                @map("after_state") @db.JsonB
  expiresAt    DateTime?           @map("expires_at") @db.Timestamptz(6)
  requestId    String              @map("request_id") @db.VarChar(128)
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  case         ModerationCase      @relation(fields: [caseId], references: [id], onDelete: Restrict)
  actor        User                @relation("ModerationActionActor", fields: [actorId], references: [id], onDelete: Restrict)
  topic        CommunityTopic?     @relation(fields: [topicId], references: [id], onDelete: Restrict)
  post         CommunityPost?      @relation(fields: [postId], references: [id], onDelete: Restrict)
  targetUser   User?               @relation("ModerationActionTargetUser", fields: [targetUserId], references: [id], onDelete: Restrict)
  node         CommunityNode?      @relation(fields: [nodeId], references: [id], onDelete: Restrict)
  sanction     ModerationSanction?

  @@index([caseId, createdAt], map: "moderation_actions_case_created_idx")
  @@index([actorId, createdAt], map: "moderation_actions_actor_created_idx")
  @@index([topicId], map: "moderation_actions_topic_idx")
  @@index([postId], map: "moderation_actions_post_idx")
  @@index([targetUserId], map: "moderation_actions_target_user_idx")
  @@index([nodeId], map: "moderation_actions_node_idx")
  @@map("moderation_actions")
}

model ModerationSanction {
  id               String           @id @default(uuid()) @db.Uuid
  userId           String           @map("user_id") @db.Uuid
  type             String           @db.VarChar(32)
  nodeId           String?          @map("node_id") @db.Uuid
  caseId           String           @map("case_id") @db.Uuid
  actionId         String           @unique(map: "moderation_sanctions_action_id_key") @map("action_id") @db.Uuid
  reason           String           @db.VarChar(500)
  startsAt         DateTime         @default(now()) @map("starts_at") @db.Timestamptz(6)
  endsAt           DateTime?        @map("ends_at") @db.Timestamptz(6)
  createdById      String           @map("created_by_id") @db.Uuid
  revokedAt        DateTime?        @map("revoked_at") @db.Timestamptz(6)
  revokedById      String?          @map("revoked_by_id") @db.Uuid
  revocationReason String?          @map("revocation_reason") @db.VarChar(500)
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  user             User             @relation("ModerationSanctionUser", fields: [userId], references: [id], onDelete: Restrict)
  node             CommunityNode?   @relation(fields: [nodeId], references: [id], onDelete: Restrict)
